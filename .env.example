# --- KiCAD Prism Root Environment Variables ---
# Use this file as a template for your own .env file at the project root.
# These variables are consumed by docker-compose and passed into backend/frontend.

# ===========================================
# Authentication (Google OAuth or Local Password + RBAC)
# ===========================================
# Friendly workspace display name shown on the login page
WORKSPACE_NAME=KiCAD Prism

# Set to false to disable authentication entirely (guest admin mode)
AUTH_ENABLED=true

# Choose authentication provider when AUTH_ENABLED=true
# Supported values: google, local
AUTH_PROVIDER=google

# Required only when AUTH_PROVIDER=google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Bootstrap local admin account (used when AUTH_PROVIDER=local)
LOCAL_BOOTSTRAP_ADMIN_USERNAME=admin
LOCAL_BOOTSTRAP_ADMIN_PASSWORD=change-me-now
LOCAL_BOOTSTRAP_ADMIN_NAME=Workspace Admin

# Optional allowlist filters (leave empty to rely only on RBAC role assignments)
# These are used only for Google auth mode.
ALLOWED_USERS_STR=
ALLOWED_DOMAINS_STR=

# Bootstrap admins (comma-separated Google account emails)
BOOTSTRAP_ADMIN_USERS_STR=admin@example.com

# Domains that receive implicit viewer access when no explicit RBAC role is set
DEFAULT_VIEWER_DOMAINS_STR=example.com,engineering.example.com

# Path override for role store file (optional)
# Defaults to <KICAD_PROJECTS_ROOT>/.rbac_roles.json
ROLE_STORE_PATH=

# Path override for local account store (optional)
# Defaults to <KICAD_PROJECTS_ROOT>/.local_accounts.json
LOCAL_ACCOUNT_STORE_PATH=

# Required: session signing secret for HttpOnly auth cookie
SESSION_SECRET=change-me-to-a-long-random-secret

# Session lifetime in hours
SESSION_TTL_HOURS=12

# Set true only behind HTTPS
SESSION_COOKIE_SECURE=false

# ===========================================
# Git & Repository Access
# ===========================================
# Optional: GitHub PAT for private repository import/sync
GITHUB_TOKEN=

# ===========================================
# Runtime / Development
# ===========================================
# Keep false for normal auth behavior
DEV_MODE=false
