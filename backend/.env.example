# KiCAD Prism Backend Configuration
# Copy this file to .env and customize for your environment

# ===========================================
# Authentication Provider + RBAC Configuration
# ===========================================
# Friendly workspace display name shown on the login page
WORKSPACE_NAME=KiCAD Prism

# Set false to disable authentication entirely
AUTH_ENABLED=true

# Supported values: google, local
AUTH_PROVIDER=google

# Google auth mode only
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Local auth mode only
LOCAL_BOOTSTRAP_ADMIN_USERNAME=admin
LOCAL_BOOTSTRAP_ADMIN_PASSWORD=change-me-now
LOCAL_BOOTSTRAP_ADMIN_NAME=Workspace Admin

# Optional allowlist filters. Used only for Google auth mode.
ALLOWED_USERS_STR=
ALLOWED_DOMAINS_STR=

# Bootstrap admin emails (comma-separated)
BOOTSTRAP_ADMIN_USERS_STR=admin@example.com

# Domains that receive implicit viewer access when no explicit RBAC role is set
DEFAULT_VIEWER_DOMAINS_STR=example.com,engineering.example.com

# Role store file path (optional override; defaults to <projects_root>/.rbac_roles.json)
ROLE_STORE_PATH=

# Local account store path (optional override; defaults to <projects_root>/.local_accounts.json)
LOCAL_ACCOUNT_STORE_PATH=

# Session signing secret (required when AUTH_ENABLED=true and DEV_MODE=false)
SESSION_SECRET=change-me-to-a-long-random-secret

# Session lifetime in hours
SESSION_TTL_HOURS=12

# Set to true only when serving over HTTPS
SESSION_COOKIE_SECURE=false

# ===========================================
# Development Settings
# ===========================================
# Keep false for normal authentication flow
DEV_MODE=false

# ===========================================
# Optional Git Access
# ===========================================
GITHUB_TOKEN=
